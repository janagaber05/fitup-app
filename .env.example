# Create React App: only variables prefixed with REACT_APP_ are exposed to the browser bundle.
# Restart `npm start` after any change.

BROWSER=open

# Supabase (use Project URL + anon public key from Dashboard → Settings → API)
# Never put service_role here — it would ship in the client bundle.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# YOLOv8 API base URL (local or hosted) — no /predict suffix
# Local example:
REACT_APP_YOLO_API_URL=http://127.0.0.1:8787
# Hosted example (Render):
# REACT_APP_YOLO_API_URL=https://fitup-yolo-api.onrender.com
REACT_APP_DETECTOR_MODE=
# Set to tensorflow to force Teachable Machine only:
# REACT_APP_DETECTOR_MODE=tensorflow

# Optional existing app keys
REACT_APP_TM_MODEL_URL=
REACT_APP_ROBOFLOW_WORKFLOW_URL=
REACT_APP_ROBOFLOW_API_KEY=
